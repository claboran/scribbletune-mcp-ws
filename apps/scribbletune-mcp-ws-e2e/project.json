{
  "name": "scribbletune-mcp-ws-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["scribbletune-mcp-ws"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/scribbletune-mcp-ws-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["scribbletune-mcp-ws:build", "scribbletune-mcp-ws:serve"]
    }
  }
}
