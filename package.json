    "mcp:inspect": "nx run scribbletune-mcp-server:inspect",
    "store:dev": "nx run scribbletune-midi-store:serve:development",
    "store:build": "nx run scribbletune-midi-store:build",
    "dev": "nx run-many --target=serve --projects=scribbletune-mcp-server,scribbletune-midi-store",
    "valkey:up": "docker compose up -d",
    "valkey:down": "docker compose down",
    "store:generate:client": "java -jar open-api-generator-cli/openapi-generator-cli.jar generate -i apps/scribbletune-mcp-server/open-api/scribbletune-open-api.yml -g typescript-fetch -o apps/scribbletune-mcp-server/src/midi-store-client --additional-properties=supportsES6=true,typescriptThreePlus=true,npmVersion=1.0.0,withInterfaces=true"
  },
  "private": true,
